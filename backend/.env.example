# App Configuration
APP_NAME="Personal Agentic AI Assistant"
APP_VERSION="0.5.0"
APP_ENV="development"
DEBUG=true
API_V1_PREFIX="/api/v1"
HOST="127.0.0.1"
PORT=8000
DATABASE_URL="sqlite:///./data/assistant.db"
LOG_LEVEL="INFO"

# Local AI (Ollama) Configuration
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="llama3.2"

# Phase 3 Configuration
MAX_CONTEXT_MESSAGES=20
MAX_CONTEXT_CHARS=12000
CONVERSATION_TITLE_MAX_LENGTH=60
WEBSOCKET_MAX_MESSAGE_CHARS=10000

# Phase 4 Configuration
AGENT_MAX_STEPS=8
AGENT_MAX_RETRIES_PER_STEP=2
AGENT_TOOL_TIMEOUT_SECONDS=30
AGENT_ROUTER_PARSE_RETRIES=1
AGENT_PLANNER_PARSE_RETRIES=1
AGENT_MAX_DUPLICATE_ACTIONS=1

# Phase 5A Configuration
WEB_SEARCH_MAX_RESULTS=10
WEB_FETCH_TIMEOUT_SECONDS=15
WEB_FETCH_MAX_BYTES=2097152
WEB_FETCH_MAX_REDIRECTS=5
WEB_READER_MAX_CHARS=20000
WEB_MAX_PAGES_PER_RUN=3


